<?xml version="1.0" encoding="utf-8"?>
<!--
  Optional layered splash (not used when config.xml points at splash_robot_artwork.png).
  AAPT2 rejects %p on item width/height here; use fixed dp if you switch the preference to this file.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
    <item
        android:width="168dp"
        android:height="200dp"
        android:gravity="center">
        <bitmap
            android:gravity="center"
            android:src="@drawable/splash_robot_artwork" />
    </item>
</layer-list>
