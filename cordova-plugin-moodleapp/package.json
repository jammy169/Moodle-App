{
  "name": "cordova-plugin-moodleapp",
  "private": true,
  "types": "./types/index.d.ts",
  "version": "0.0.0",
  "scripts": {
    "dev": "concurrently \"npm run dev:ts\" \"npm run dev:cordova\"",
    "dev:ts": "node ./scripts/build.js --watch",
    "dev:cordova": "chokidar www/index.js -c node ./scripts/copy-javascript.js",
    "prod": "node -e \"process.env.NODE_ENV='production'; require('./scripts/build.js')\"",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "chokidar-cli": "3.0.0",
    "concurrently": "9.2.1",
    "esbuild": "0.28.0",
    "typescript": "5.9.3"
  }
}
